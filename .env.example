# 应用于余弦相似度计算的，调用text-embedding-3-small的api
OPENAI_BASE_URL=https://your_base_url
OPENAI_API_KEY=your_api_key

# 模型api
OPENAI_CHAT_URL=https://your_chat_url
OPENAI_API_SECRET_KEY=your_api_key

# 本地数据和模型
MAPFIN_DATA_PATH=./data
MAPFIN_MODEL_PATH=/absolute/path/to/local/model
MAPFIN_TOKENIZER_PATH=/absolute/path/to/local/model
MAPFIN_EVAL_SPLIT=test
MAPFIN_DEVICE=auto
MAPFIN_MAX_GEN_TOKS=150
